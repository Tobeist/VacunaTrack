# .env.example — Copia este archivo como ".env" y llena los valores
#
# Si DATABASE_URL está vacío o no existe, el sistema usa data.py (modo demo).
# Si DATABASE_URL tiene valor, el sistema conecta a PostgreSQL real.

# Conexión a PostgreSQL
DATABASE_URL=postgresql://vacunatrack_user:666@localhost:5432/vacunatrack

# Clave secreta de Flask (cámbiala en producción)
SECRET_KEY=vacunatrack-dev-secret-2026

# Conexión a MongoDB (Atlas o instancia local/VM)
MONGO_URL=mongodb://localhost:27017
MONGO_DB=vacunatrack
